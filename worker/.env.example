# Worker environment. Copy to .env and fill in.

REDIS_URL=redis://redis:6379/0

# Supabase — service role key (Project Settings → API). Bypasses RLS.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# HuggingFace scoring model — HiruniAyesha/jetwing-customer-ranker (Gradio Space).
# Defaults to the public Space below; the worker scores each customer via its
# /predict endpoint. Set HF_SCORING_SPACE="" to fall back to the local RFM heuristic.
HF_SCORING_SPACE=HiruniAyesha/jetwing-customer-ranker
# HF_API_TOKEN=hf_...                       # only required if the Space is private
# HF_SCORING_ENDPOINT=https://xxxxx.endpoints.huggingface.cloud   # legacy, optional
# HF_MODEL_VERSION=jetwing-customer-ranker-v2

# PMS (optional — mock adapter is used until both are set)
# PMS_BASE_URL=https://pms.example.com/api
# PMS_API_KEY=...

# Tuning
SCORING_BATCH_SIZE=500
WORKER_TIMEZONE=Asia/Colombo
