# Worker environment. Copy to .env and fill in.

REDIS_URL=redis://redis:6379/0

# Supabase — service role key (Project Settings → API). Bypasses RLS.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# HuggingFace scoring model — HiruniAyesha/jetwing-customer-ranker (handler_v2).
# Deploy it as a Dedicated Inference Endpoint (custom handler), then paste the URL.
# Leave HF_SCORING_ENDPOINT unset to use the local RFM heuristic instead.
# HF_SCORING_ENDPOINT=https://xxxxx.endpoints.huggingface.cloud
# HF_API_TOKEN=hf_...
# HF_MODEL_VERSION=jetwing-customer-ranker-v2

# PMS (optional — mock adapter is used until both are set)
# PMS_BASE_URL=https://pms.example.com/api
# PMS_API_KEY=...

# Tuning
SCORING_BATCH_SIZE=500
WORKER_TIMEZONE=Asia/Colombo
