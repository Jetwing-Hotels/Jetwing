# ── Supabase ──────────────────────────────────────────────────────────────────
# Find these in your Supabase dashboard → Project Settings → API
# Public (safe to expose to the browser):
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only (NEVER expose to the browser). Bypasses Row Level Security.
# Used by API routes / workers for ETL, scoring, and email generation.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Gemini (Edge Functions) ──────────────────────────────────────────────────
# Offer/email generation runs inside Supabase Edge Functions and calls Gemini.
# Set as Supabase secrets, not here:  supabase secrets set GEMINI_API_KEY=...
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-2.5-flash          # optional override (default: gemini-2.5-flash)

# Optional shared secret guarding the Edge Functions. If set here AND as a
# Supabase secret, the Next.js routes forward it as x-function-secret.
# EDGE_FUNCTION_SECRET=

# ── Customer-ranker model (HiruniAyesha/jetwing-customer-ranker, Gradio Space) ─
# /api/guests/score proxies to this Space. Override the URL only if you fork it.
# HF_SCORING_SPACE_URL=https://hiruniayesha-jetwing-customer-ranker.hf.space
# HF_API_TOKEN=hf_...                      # only required if the Space is private

# ── Email sending (Gmail SMTP via Nodemailer) ────────────────────────────────
# Campaign / offer emails are sent from the Next.js API routes. For Gmail:
#   1. Enable 2-Step Verification on the Google account.
#   2. Create an App Password (Google Account → Security → App passwords).
#   3. Use that 16-char app password as SMTP_PASS (NOT your normal password).
# Without these, sending falls back to a safe dry run (no external email).
# SMTP_USER=youraddress@gmail.com
# SMTP_PASS=your-16-char-app-password
# EMAIL_FROM=Jetwing Symphony <youraddress@gmail.com>
# SMTP_HOST=smtp.gmail.com                  # optional override
# SMTP_PORT=465                             # optional override (465 TLS, 587 STARTTLS)
# EMAIL_OVERRIDE_TO=                        # optional: redirect every email to one inbox (testing)

# ── SMS sending (Twilio) ─────────────────────────────────────────────────────
# Guests with NO email on file (typically OTA bookings) are reached by SMS instead,
# with a short message + a link to jetwinghotels.com. Twilio's free trial gives
# credits at no cost (trial mode can only text *verified* numbers).
#   1. Create a Twilio account → get a trial number.
#   2. Copy the Account SID + Auth Token from the Twilio console.
# Without these, SMS falls back to a safe dry run (no external SMS).
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_FROM=+1234567890                   # your Twilio number (E.164)
# SMS_DEFAULT_COUNTRY_CODE=+94              # optional: normalise local numbers (default +94 Sri Lanka)
# SMS_OVERRIDE_TO=                          # optional: redirect every SMS to one phone (testing)

# ── External services (optional) ─────────────────────────────────────────────
# HF_SCORING_ENDPOINT=https://...          # legacy dedicated endpoint (optional)
# HF_MODEL_VERSION=v1
